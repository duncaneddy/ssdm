# S3-compatible object storage (Cloudflare R2, AWS S3, MinIO, …).
# Create an access key / secret with object read & write on the bucket.
BUCKET_ACCESS_KEY_ID=your-access-key-id
BUCKET_SECRET_ACCESS_KEY=your-secret-access-key
# Full S3 endpoint URL. For R2: https://<account-id>.r2.cloudflarestorage.com
BUCKET_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
# Public serving domain (the bucket's CDN / custom domain) — used to build the
# download links shown on the landing page.
SITE_DOMAIN=yourgreatdomain.com

# Optional overrides (defaults shown)
# BUCKET_NAME=ssdm-data
# BUCKET_REGION=auto      # R2 ignores region; AWS S3 needs the bucket's real region (e.g. us-east-1)
# BUCKET_URL_STYLE=path   # "path" (R2/MinIO/B2/Wasabi) or "virtual" (AWS S3 virtual-hosted)
# DATA_DIR defaults to /data (the Docker volume). For a local `cargo run`,
# set it to a writable local path, e.g.:
# DATA_DIR=./data
# RUN_ON_START=false
# HOST_MIN_INTERVAL_SECS=2
# STAGGER_JITTER_SECS=1
# RUST_LOG=info
